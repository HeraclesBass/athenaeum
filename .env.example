# Athenaeum — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database (required) ────────────────────────────────────────────────────────
ATHENAEUM_DB_PASSWORD=changeme

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Supported: openrouter | openai | anthropic | ollama | gemini
LLM_PROVIDER=openrouter
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# For OpenRouter (free tier available): get a key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# For Ollama (local, no key needed):
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434

# For OpenAI-compatible APIs:
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://your-api:8000/v1
# LLM_API_KEY=your-key

# ── Frontend (baked into Next.js at build time) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8140
NEXT_PUBLIC_APP_URL=http://localhost:3140

# ── Auth (optional) ───────────────────────────────────────────────────────────
# Set if you use an external SSO provider (e.g., Authelia, Authentik)
# NEXT_PUBLIC_AUTH_URL=https://auth.example.com
# APP_URL=https://your-domain.com
